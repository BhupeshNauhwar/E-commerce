<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration</title>
    <link rel="stylesheet" href="css/register.css">
   
</head>
<body>



<div class="wrapper">
  <div class="form login">
       
    <form action="" method="post" >
      <div class="userlogin"> Regisrtation Form</div>
       {{#if message}}
        <p class="message" style="color: green;">{{message}}</p>
            {{/if}}
       </span>
   
    <input type="text" name="name" placeholder="Enter Name" required><br><br>
    <input type="text" name="mob" placeholder="Enter Mobile" required><br><br>
    <input type="email" name="email" placeholder="Enter Email" required><br><br>
    <input type="password" name="password" placeholder="Enter Password" required><br><br>
    <input type="text" name="address" placeholder="Enter Address" required><br><br>
    <input type="text" name="pc" placeholder="Enter Pincode" required><br><br>
    <input type="submit" name="register" id="">
    
  </form> 
  <div ><button class="adminbtn"><a href="/login">Login</a></button></div>
  </div> </div>

</body>
</html>